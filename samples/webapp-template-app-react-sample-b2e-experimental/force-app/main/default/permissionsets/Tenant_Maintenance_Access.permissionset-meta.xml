<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Tenant access: create and manage only their own maintenance requests. No View All / Modify All — tenants see only records they own. Assign to tenant users; do not assign Property Management Access.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>Tenant Maintenance Access</label>

    <!-- Object: Maintenance_Request__c — CRUD only (no viewAllRecords/modifyAllRecords); with OWD Private, tenants see only records they own -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <object>Maintenance_Request__c</object>
    </objectPermissions>
    <!-- Property__c — read-only for address display on maintenance list -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <object>Property__c</object>
    </objectPermissions>
    <!-- Tenant__c — read-only so tenant can resolve their own record -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <object>Tenant__c</object>
    </objectPermissions>

    <!-- Field Permissions: Maintenance_Request__c -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Maintenance_Request__c.User__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Maintenance_Request__c.Property__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Maintenance_Request__c.Type__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Maintenance_Request__c.Priority__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Maintenance_Request__c.Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Maintenance_Request__c.Description__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Maintenance_Request__c.Scheduled__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Maintenance_Request__c.Completed__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Maintenance_Request__c.Est_Cost__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Maintenance_Request__c.Actual_Cost__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Maintenance_Request__c.Tenant_Home__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Maintenance_Request__c.Assigned_Worker__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Field Permissions: Property__c (for list/detail) -->
    <fieldPermissions>
        <editable>false</editable>
        <field>Property__c.Address__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Field Permissions: Tenant__c -->
    <fieldPermissions>
        <editable>false</editable>
        <field>Tenant__c.User__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Tenant__c.User_Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Tenant__c.Property__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Tenant__c.Start_Date__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Tenant__c.End_Date__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Tenant__c.Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
</PermissionSet>
